# Test-only env vars for the Playwright suite.
# Copy to .env.test.local — never commit the real file.

# The deployed site under test. Default in playwright.config.ts is the prod URL.
PLAYWRIGHT_BASE_URL=https://pleasepleasepleasewater.me

# Optional — if set, the privacy + digest specs hit the Supabase REST API
# directly to assert RLS blocks and re-invoke the cron. Pull from
# https://supabase.com/dashboard/project/dftjobtwildtdfpnqqyu/settings/api
SUPABASE_URL=https://dftjobtwildtdfpnqqyu.supabase.co
SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Required for digest.spec.ts only — same value as the cron job uses to
# invoke send-watering-reminder.
CRON_SHARED_SECRET=...

# Required for resend-audit verification — your Resend API key.
# Resend lets you list recent messages with a read-only key if you have one;
# otherwise omit and the audit spec will skip the Resend assertion.
RESEND_API_KEY=re_...
